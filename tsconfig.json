{
  "extends": "@homeassistant-extras/config/tsconfig.base.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "paths": {
      "@cards/*": ["./src/cards/*"],
      "@type/*": ["./src/types/*"],
      "@config/*": ["./src/config/*"],
      "@delegates/*": ["./src/delegates/*"],
      "@editor/*": ["./src/editor/*"],
      "@html/*": ["./src/html/*"],
      "@localize/*": ["./src/localize/*"],
      "@util/*": ["./src/util/*"],
      "@theme/*": ["./src/theme/*"],
      "@test/*": ["./test/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
